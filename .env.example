# ============================================================
# BillBreakdown — Environment Variables (copy to .env)
# ============================================================

# --- Database (Neon / Vercel Postgres) ----------------------
# Pooled connection (used by Prisma at runtime)
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# Direct / unpooled connection (used by Prisma migrations)
DIRECT_URL=postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require

# --- Congress.gov API ---------------------------------------
# Get a free key at https://api.data.gov/signup/
CONGRESS_API_KEY=your_congress_api_key_here

# --- LegiScan API -------------------------------------------
# Get a free key at https://legiscan.com/legiscan
LEGISCAN_API_KEY=your_legiscan_api_key_here

# Comma-separated list of state abbreviations to ingest (default: RI)
LEGISCAN_BATCH_STATES=RI

# --- Anthropic Claude API -----------------------------------
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Cron job secret ----------------------------------------
# Any random string — used to authenticate manual cron triggers
CRON_SECRET=your_cron_secret_here
